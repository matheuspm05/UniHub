() Tj
T*
() Tj
T*
(def create_app\(test_config=None\):) Tj
T*
(    flask_app = Flask\(__name__, template_folder="templates", static_folder="static"\)) Tj
T*
(    init_config\(flask_app, test_config\)) Tj
T*
(    init_db\(flask_app\)) Tj
T*
(    register_models\(\)) Tj
T*
(    init_login\(flask_app\)) Tj
T*
(    init_wtf\(flask_app\)) Tj
T*
(    init_views\(flask_app\)) Tj
T*
(    init_swagger\(flask_app\)) Tj
T*
(    register_seed_command\(flask_app\)) Tj
T*
(    return flask_app) Tj
