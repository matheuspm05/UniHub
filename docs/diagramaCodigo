class Usuario {
    +int id
    +string nome
    +string email
    +string senha_hash
    +string curso
    +string periodo
    +string cidade
    +string bio
    +string instagram
    +string linkedin
    +string whatsapp
    +string role
    +string selo
    +bool ativo
    +datetime criado_em
    +datetime atualizado_em

    +definirSenha()
    +verificarSenha()
    +toDict()
    +toPublicDict()
}

class Evento {
